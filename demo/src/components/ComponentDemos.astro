---
import CodeViewerButton from './CodeViewerButton'

const sources = {
  multiHue: `<div class="hue-primary chroma-[6] bg-lc-[93] text-lc-[15] border-lc-[90] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Multi-Hue Composition</h4>
  <p class="text-lc-[45] text-[0.85rem] leading-normal mb-4">
    hue-primary on the container. Badges swap hue — L and C stay identical.
  </p>
  <div class="flex flex-wrap gap-2 mt-2 *:px-3 *:py-1 *:rounded-full *:text-xs *:font-semibold">
    <span class="hue-primary bg-lc-[68] chroma-[12] text-lc-[15]">primary</span>
    <span class="hue-accent bg-lc-[68] chroma-[12] text-lc-[15]">accent</span>
    <span class="hue-warning bg-lc-[68] chroma-[12] text-lc-[15]">warning</span>
    <span class="hue-success bg-lc-[68] chroma-[12] text-lc-[15]">success</span>
    <span class="hue-info bg-lc-[68] chroma-[12] text-lc-[15]">info</span>
    <span class="hue-danger bg-lc-[68] chroma-[12] text-lc-[15]">danger</span>
  </div>
</div>`,
  cascade: `<div class="hue-accent chroma-[18] bg-lc-[68] text-lc-[15] border-lc-[20] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Cascade Override</h4>
  <p class="text-[0.85rem] leading-normal mb-4">
    Parent sets hue-accent chroma-[18] bg-lc-[68]. Children inherit
    chroma + hue, override only luminance.
  </p>
  <div class="flex gap-2 font-mono font-semibold *:px-4 *:py-2 *:rounded-lg *:text-[0.75rem]">
    <div class="bg-lc-[95] text-lc-[15]">bg-lc-[95]</div>
    <div class="bg-lc-[40] text-lc-[90]">bg-lc-[40]</div>
    <div class="bg-lc-[15] text-lc-[88]">bg-lc-[15]</div>
  </div>
</div>`,
  chroma: `<div class="hue-success chroma-[6] bg-lc-[95] text-lc-[40] border-lc-[50] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Chroma for Activity</h4>
  <p class="text-lc-[50] chroma-[4] text-[0.85rem] leading-normal mb-4">
    On hover, these buttons increase chroma and get a little shadow.
  </p>
  <div class="flex gap-2 *:px-5 *:py-2 *:rounded-lg *:text-[0.8rem] *:font-semibold *:cursor-pointer *:transition-all *:duration-150 *:border *:hover:shadow">
    <div class="bg-lc-[68] chroma-[12] text-lc-[15] hover:chroma-[18] hover:border-c-[12]">success</div>
    <div class="bg-lc-[95] chroma-[4] text-lc-[22] chroma-[16] border-lc-[78] hover:bg-c-[6] hover:border-c-[18]">outline</div>
  </div>
</div>`,
  luminance: `<div class="hue-primary chroma-[12] bg-lc-[95] text-lc-[35] border-lc-[68] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Luminance for Emphasis</h4>
  <p class="text-lc-[50] text-[0.85rem] leading-normal mb-4">
    Every element uses the same chroma and hue. Other elements only
    change luminance. Excellent for accessibility.
  </p>
  <div class="flex gap-2 *:px-5 *:py-2 *:rounded-lg *:text-[0.8rem] *:font-semibold *:cursor-pointer *:transition-all *:duration-150 *:border *:shadow">
    <div class="bg-lc-[42] text-lc-[93] border-lc-[48] hover:bg-lc-[48] hover:border-lc-[55] hover:text-lc-[96]">primary</div>
    <div class="border-lc-[88] hover:text-lc-[42] hover:bg-lc-[88] hover:border-lc-[70]">outline</div>
  </div>
</div>`,
  danger: `<div class="hue-danger chroma-[12] bg-lc-[88] text-lc-[15] border-lc-[68] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Danger Alert</h4>
  <p class="text-lc-[22] chroma-[5] text-[0.85rem] leading-normal mb-4">
    hue-danger on the container — every child inherits the hue.
    Only luminance and chroma vary per element.
  </p>
  <div class="flex gap-2 *:px-5 *:py-2 *:rounded-lg *:text-[0.8rem] *:font-semibold *:border-0 *:cursor-pointer *:transition-all *:duration-150">
    <div class="bg-lc-[45] chroma-[18] text-lc-[95]">Acknowledge</div>
    <div class="bg-lc-[45] chroma-[18] text-lc-[15]">Cancel</div>
  </div>
</div>`,
  axis: `<div class="hue-primary chroma-[6] bg-lc-[90] text-lc-[15] border-lc-[90] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Axis Inheritance</h4>
  <p class="text-lc-[50] chroma-[2] text-[0.85rem] leading-normal mb-4">
    Parent sets hue to primary. Children swap only the hue axis —
    luminance and chroma stay inherited.
  </p>
  <div class="flex gap-2 mt-2 font-mono font-semibold *:bg-lc-[68] *:chroma-[12] *:text-center *:px-3 *:py-1.5 *:rounded-full *:text-xs">
    <span class="bg-h-success text-lc-[15]">bg-h-success</span>
    <span class="bg-h-warning text-lc-[15]">bg-h-warning</span>
    <span class="bg-h-danger text-lc-[15]">bg-h-danger</span>
  </div>
</div>`,
  arbitrary: `<div class="hue-[180] chroma-[15] bg-lc-[15] text-lc-[90] border-lc-[30] rounded-xl p-6 border">
  <h4 class="text-[0.85rem] mb-3 font-semibold">Arbitrary Values</h4>
  <p class="text-lc-[65] text-[0.85rem] leading-normal mb-4">
    hue-[180] for a custom hue, chroma-[15] for exact chroma.
    Luminance auto-flips between light and dark mode.
  </p>
  <div class="flex flex-wrap gap-2 mt-2 *:px-3 *:py-1 *:rounded-full *:text-xs *:font-semibold">
    <span class="bg-lc-[30] text-lc-[90]">lc-[30]</span>
    <span class="bg-lc-[50] text-lc-[95]">lc-[50]</span>
    <span class="bg-lc-[70] text-lc-[15]">lc-[70]</span>
  </div>
</div>`,
}
---

<div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-6">
    <!-- Multi-Hue Composition -->
  <div class="relative hue-primary chroma-[6] bg-lc-[93] text-lc-[15] border-lc-[90] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.multiHue} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Multi-Hue Composition</h4>
    <p class="text-lc-[45] text-[0.85rem] leading-normal mb-4">
      hue-primary on the container. Badges swap hue — L and C stay identical:
    </p>
    <div class="flex flex-wrap gap-2 mt-2 *:px-3 *:py-1 *:rounded-full *:text-xs *:font-semibold">
      <span class="hue-primary bg-lc-[68] chroma-[12] text-lc-[15]">primary</span>
      <span class="hue-accent bg-lc-[68] chroma-[12] text-lc-[15]">accent</span>
      <span class="hue-warning bg-lc-[68] chroma-[12] text-lc-[15]">warning</span>
      <span class="hue-success bg-lc-[68] chroma-[12] text-lc-[15]">success</span>
      <span class="hue-info bg-lc-[68] chroma-[12] text-lc-[15]">info</span>
      <span class="hue-danger bg-lc-[68] chroma-[12] text-lc-[15]">danger</span>
    </div>
  </div>

  <!-- Cascade Demo -->
  <div class="relative hue-accent chroma-[18] bg-lc-[68] text-lc-[15] border-lc-[20] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.cascade} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Cascade Override</h4>
    <p class="text-[0.85rem] leading-normal mb-4">
      Parent sets hue-accent chroma-[18] bg-lc-[68]. Children inherit chroma + hue, override only
      luminance — no need to redeclare the full color.
    </p>
    <div class="flex gap-2 font-mono font-semibold *:px-4 *:py-2 *:rounded-lg *:text-[0.75rem]">
      <div class="bg-lc-[95] text-lc-[15]">bg-lc-[95]</div>
      <div class="bg-lc-[40] text-lc-[90]">bg-lc-[40]</div>
      <div class="bg-lc-[15] text-lc-[88]">bg-lc-[15]</div>
    </div>
  </div>

  <!-- Chroma Card Success -->
  <div class="relative hue-success chroma-[6] bg-lc-[95] text-lc-[40] border-lc-[50] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.chroma} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Chroma for Activity</h4>
    <p class="text-lc-[50] chroma-[4] text-[0.85rem] leading-normal mb-4">
      On hover, these buttons increase chroma and get a little shadow. Subtle, pleasing, unlikely to distract.
    </p>
    <div class="flex gap-2 *:px-5 *:py-2 *:rounded-lg *:text-[0.8rem] *:font-semibold *:cursor-pointer *:transition-all *:duration-150 *:border *:hover:shadow">
      <div class="bg-lc-[68] chroma-[12] text-lc-[15] hover:chroma-[18] hover:border-c-[12]">
        success
      </div>
      <div class="bg-lc-[95] chroma-[4] text-lc-[22] chroma-[16] border-lc-[78] hover:bg-c-[6] hover:border-c-[18]">
        outline
      </div>
    </div>
  </div>

  <!-- Luminance Card Primary -->
  <div class="relative hue-primary chroma-[12] bg-lc-[95] text-lc-[35] border-lc-[68] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.luminance} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Luminance for Emphasis</h4>
    <p class="text-lc-[50] text-[0.85rem] leading-normal mb-4">
      Every element in this card uses the same chroma and hue. Other elements only change luminance. Excellent for accessibility.
    </p>
    <div class="flex gap-2 *:px-5 *:py-2 *:rounded-lg *:text-[0.8rem] *:font-semibold *:cursor-pointer *:transition-all *:duration-150 *:border *:shadow">
      <div class="bg-lc-[42] text-lc-[93] border-lc-[48] hover:bg-lc-[48] hover:border-lc-[55] hover:text-lc-[96]">
        primary
      </div>
      <div class="border-lc-[88] hover:text-lc-[42] hover:bg-lc-[88] hover:border-lc-[70]">
        outline
      </div>
    </div>
  </div>

  <!-- Danger Alert -->
  <div class="relative hue-danger chroma-[12] bg-lc-[88] text-lc-[15] border-lc-[68] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.danger} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Danger Alert</h4>
    <p class="text-lc-[22] chroma-[5] text-[0.85rem] leading-normal mb-4">
      hue-danger on the container — every child inherits the hue.
      Only luminance and chroma vary per element.
    </p>
    <div class="flex gap-2 *:px-5 *:py-2 *:rounded-lg *:text-[0.8rem] *:font-semibold *:border-0 *:cursor-pointer *:transition-all *:duration-150">
      <div class="bg-lc-[45] chroma-[18] text-lc-[95]">
        Acknowledge
      </div>
      <div class="bg-lc-[45] chroma-[18] text-lc-[15]">
        Cancel
      </div>
    </div>
  </div>

  <!-- Axis Inheritance -->
  <div class="relative hue-primary chroma-[6] bg-lc-[90] text-lc-[15] border-lc-[90] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.axis} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Axis Inheritance</h4>
    <p class="text-lc-[50] chroma-[2] text-[0.85rem] leading-normal mb-4">
      Parent sets hue to primary. Children swap only the hue axis — luminance
      and chroma stay inherited.
    </p>
    <div class="flex gap-2 mt-2 font-mono font-semibold *:bg-lc-[68] *:chroma-[12] *:text-center *:px-3 *:py-1.5 *:rounded-full *:text-xs">
      <span class="bg-h-success text-lc-[15]">bg-h-success</span>
      <span class="bg-h-warning text-lc-[15]">bg-h-warning</span>
      <span class="bg-h-danger text-lc-[15]">bg-h-danger</span>
    </div>
  </div>

  <!-- Arbitrary Values -->
  <div class="relative hue-[180] chroma-[15] bg-lc-[15] text-lc-[90] border-lc-[30] rounded-xl p-6 border">
    <CodeViewerButton client:load code={sources.arbitrary} />
    <h4 class="text-[0.85rem] mb-3 font-semibold">Arbitrary Values</h4>
    <p class="text-lc-[65] text-[0.85rem] leading-normal mb-4">
      hue-[180] for a custom hue, chroma-[15] for exact chroma.
      Luminance auto-flips between light and dark mode.
    </p>
    <div class="flex flex-wrap gap-2 mt-2 *:px-3 *:py-1 *:rounded-full *:text-xs *:font-semibold">
      <span class="bg-lc-[30] text-lc-[90]">lc-[30]</span>
      <span class="bg-lc-[50] text-lc-[95]">lc-[50]</span>
      <span class="bg-lc-[70] text-lc-[15]">lc-[70]</span>
    </div>
  </div>
</div>
