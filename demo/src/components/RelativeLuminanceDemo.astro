---
const navbars = [
  { hue: 'hue-primary', chroma: 'chroma-[12]', bg: 'bg-lc-[75]', text: 'text-lc-[15]', label: 'primary', items: ['Dashboard', 'Projects', 'Team'] },
  { hue: 'hue-accent', chroma: 'chroma-[18]', bg: 'bg-lc-[68]', text: 'text-lc-[15]', label: 'accent', items: ['Browse', 'Trending', 'Library'] },
  { hue: 'hue-success', chroma: 'chroma-[12]', bg: 'bg-lc-[75]', text: 'text-lc-[15]', label: 'success', items: ['Overview', 'Analytics', 'Reports'] },
  { hue: 'hue-danger', chroma: 'chroma-[12]', bg: 'bg-lc-[88]', text: 'text-lc-[15]', label: 'danger', items: ['Alerts', 'Incidents', 'Escalations'] },
]
---

<div class="flex flex-col gap-4">
  {navbars.map(({ hue, chroma, bg, text, label, items }) => (
    <div class:list={[hue, chroma, bg, text, 'rounded-lg flex items-center gap-1 px-2 py-2 text-[0.75rem] sm:text-[0.82rem] font-medium']}>
      <div class="flex-1 flex items-center gap-1 min-w-0 overflow-hidden">
        <div class="bg-lc-up-2 rounded px-2 sm:px-2.5 py-1.5 font-bold text-[0.75rem] sm:text-[0.8rem] mr-1 sm:mr-2 tracking-tight shrink-0">{label}</div>
        {items.map((itemLabel, i) => (
          <a class:list={[
            'px-2 sm:px-3 py-1.5 rounded transition-all duration-150 cursor-pointer whitespace-nowrap',
            i === 0 ? 'bg-lc-up-1' : 'hover:bg-lc-up-1',
          ]}>
            {itemLabel}
          </a>
        ))}
      </div>
      <a class="shrink-0 bg-lc-down-1 rounded px-2 py-1.5 cursor-pointer hover:bg-lc-down-2 transition-all duration-150" title="More">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
      </a>
      <div class="hidden sm:flex items-center gap-1 text-[0.72rem] font-mono opacity-70 shrink-0 ml-auto">
        <div class="bg-lc-down-1 rounded px-2 py-1">down-1</div>
        <div class="bg-lc-up-1 rounded px-2 py-1">up-1</div>
        <div class="bg-lc-up-2 rounded px-2 py-1">up-2</div>
      </div>
    </div>
  ))}
  <p class="hue-neutral text-lc-[50] chroma-[2] text-[0.8rem] leading-relaxed mt-1">
    Each navbar sets a single base color with <code class="hue-primary text-lc-[40] chroma-[16] font-mono text-[0.78rem]">hue-*</code> and <code class="hue-primary text-lc-[40] chroma-[16] font-mono text-[0.78rem]">chroma-[N]</code>. <code class="hue-primary text-lc-[40] chroma-[16] font-mono text-[0.78rem]">bg-lc-up-1</code> and
    <code class="hue-primary text-lc-[40] chroma-[16] font-mono text-[0.78rem]">bg-lc-down-1</code> nudge luminance toward or away from the
    viewer — the direction flips automatically in dark mode. Same utility classes, every hue.
  </p>
</div>
